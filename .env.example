# ---------------------------------------------------------------
# Household Budget — environment variables
# Copy this file to .env and fill in the values.
# The install script generates SECRET_KEY automatically,
# but you can set it manually with: openssl rand -hex 32
# ---------------------------------------------------------------

# Required — app refuses to start without a strong key
SECRET_KEY=

# Optional — Plaid automatic bank sync
# Sign up free at https://dashboard.plaid.com/signup
# Use PLAID_ENV=sandbox to test with fake credentials first
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# Optional — Google Calendar overlay on the home page calendar
# Paste the "Secret address in iCal format" from your Google Calendar settings
GOOGLE_CALENDAR_ICS=
